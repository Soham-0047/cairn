# --- Server ---
PORT=4001
NODE_ENV=development
LOG_LEVEL=info

# Frontend (admin UI) origin — used for CORS + OAuth redirect
FRONTEND_URL=http://localhost:3001

# Public URL the backend is reachable at — used to build the Google OAuth redirect_uri
BACKEND_PUBLIC_URL=http://localhost:4001

# --- Database ---
# Use a SEPARATE database from any consumer project. The admin vault is its own
# concern and should outlive any one product's DB lifecycle.
MONGODB_URI=mongodb://localhost:27017/admin_service

# --- Encryption ---
# Used to derive the AES-256-GCM key for credential secrets. Min 16 chars.
# CHANGING THIS WILL RENDER EXISTING CREDENTIALS UNDECRYPTABLE — treat as load-bearing.
SECRET_KEY=change-me-to-a-long-random-string-please

# --- Session (Google OAuth → JWT cookie) ---
# Used to sign the admin session JWT stored in the http-only cookie.
SESSION_SECRET=change-me-to-another-long-random-string
SESSION_HOURS=168                  # 7 days

# --- Google OAuth (admin UI login) ---
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: <BACKEND_PUBLIC_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated allowlist — only these email addresses can sign in.
ADMIN_EMAILS=you@example.com

# --- Service token (consumer-project auth) ---
# Long random string. Each consumer project sets the same value as
# ADMIN_SERVICE_TOKEN in its own .env and sends it as `Authorization: Bearer ...`
# when hitting /public/* endpoints.
SERVICE_TOKEN=change-me-to-a-long-random-string-yet-again
