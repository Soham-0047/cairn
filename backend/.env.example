# Server
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
FRONTEND_URL=http://localhost:3000

# Mongo
MONGODB_URI=mongodb://localhost:27017/cairn
# Or MongoDB Atlas free-tier URI:
# MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/cairn?retryWrites=true&w=majority

# Auth — JWT (issued after NextAuth completes; verified here)
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ISSUER=cairn

# Admin panel — single token gate
ADMIN_SECRET=replace-me-with-a-long-random-string

# GitHub OAuth (frontend handles login; backend uses user's access_token for repo reads)
GITHUB_TOKEN_FOR_PUBLIC_READS=

# ============================================================
# LLM PROVIDERS — fill the ones you have. The router will skip
# missing providers automatically. Gemma 4 first, fallbacks last.
# ============================================================

# Google AI Studio — get at https://aistudio.google.com/apikey
# Used for: Gemma 4 (E2B/E4B/27B), Gemini 2.5 Flash, Gemini 2.5 Pro
GOOGLE_AI_API_KEY=

# OpenRouter — get at https://openrouter.ai/keys
# Used for: Gemma 4 31B free, DeepSeek V3 free, Llama 3.3 70B free
OPENROUTER_API_KEY=

# Groq — get at https://console.groq.com/keys
# Used for: hardware-accelerated Llama / Gemma — latency-critical paths
GROQ_API_KEY=

# Cerebras — get at https://cloud.cerebras.ai
# Used for: fast Llama for bulk batch passes
CEREBRAS_API_KEY=

# Together AI — get at https://api.together.xyz/settings/api-keys
# Used for: fallback when others are throttled
TOGETHER_API_KEY=

# HuggingFace — get at https://huggingface.co/settings/tokens
# Used for: code embeddings (CodeBERT) for originality checks
HF_API_KEY=

# ============================================================
# RESOURCE SEARCH — live tutorial discovery for path milestones
# ============================================================

# Exa.ai — get free at https://exa.ai — 1000 searches/month
# Used for: live semantic search of free tutorials per milestone
EXA_API_KEY=

# Tavily — get free at https://tavily.com — optional fallback when Exa is down
EXA_FALLBACK_TAVILY_KEY=

# ============================================================
# VECTOR STORE — "similar past learners" recall for path gen
# ============================================================

# Qdrant Cloud — free cluster at https://cloud.qdrant.io
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=cairn_paths

# ============================================================
# EMAIL — Resend transactional emails
# ============================================================

# Resend — get free at https://resend.com — 3000 emails/month
RESEND_API_KEY=
FROM_EMAIL=onboarding@resend.dev

# ============================================================
# ADMIN SERVICE — centralized credential vault / site config
# ============================================================
# When enabled, gamma pulls API keys + site config from a standalone
# admin-service over HTTP instead of its local Mongo `ApiCredential` /
# `SiteConfig` collections. See /admin-service/README.md.
#
# Leave ADMIN_SERVICE_ENABLED=false (or unset) to keep using the legacy local
# admin panel at /api/admin/* — this is the safe default during migration.

ADMIN_SERVICE_ENABLED=false
ADMIN_SERVICE_URL=http://localhost:4001
ADMIN_SERVICE_TOKEN=
# Optional — the SiteConfig key to load. Use a unique value per product if
# you host configs for several projects in one admin-service.
ADMIN_SERVICE_PRODUCT_KEY=default
# How often the in-memory credential cache is refreshed from the admin-service.
ADMIN_SERVICE_TTL_SEC=60
